# Copy to .env and fill in whichever provider you want to use.
# Leave unset to run the demos in deterministic offline mode.

# OpenAI via LangChain provider string, for example openai:gpt-4.1-mini or openai:gpt-5-mini
OPENAI_API_KEY=
AGENT_MODEL_OPENAI=openai:gpt-4.1-mini

# Anthropic via LangChain provider string, for example anthropic:claude-3-5-haiku-latest
ANTHROPIC_API_KEY=
AGENT_MODEL_ANTHROPIC=anthropic:claude-3-5-haiku-latest

# OpenRouter via langchain-openrouter, for example openrouter:openai/gpt-4o-mini
OPENROUTER_API_KEY=
AGENT_MODEL_OPENROUTER=openrouter:openai/gpt-4o-mini

# Ollama local model. Start Ollama separately and pull the model first.
OLLAMA_BASE_URL=http://localhost:11434
AGENT_MODEL_OLLAMA=ollama:llama3.1

# Provider selection: auto, openai, anthropic, openrouter, ollama, offline
AGENT_PROVIDER=auto
AGENT_TEMPERATURE=0

# LangSmith tracing is optional. Do not commit real keys.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-agent-patterns-demo
